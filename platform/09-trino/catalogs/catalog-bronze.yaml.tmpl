# Trino-catalog `bronze` — onveranderbare brondata.
#
# Template: connector-block wordt door scripts/render-trino-catalogs.py
# vervangen op basis van platform-config.yaml::table_format.
#
# Selector: het label `trino: uwv-trino` koppelt deze catalog aan de
# TrinoCluster met dezelfde label-selector (zie 09-trino/trinocluster.yaml).
---
apiVersion: trino.stackable.tech/v1alpha1
kind: TrinoCatalog
metadata:
  name: bronze
  namespace: uwv-platform
  labels:
    trino: uwv-trino
    uwv.nl/zone: bronze
    uwv.nl/format: __TABLE_FORMAT__
  annotations:
    uwv.nl/description: "Bronze layer — raw, immutable. Includes PII; OPA enforces strict access (TODO fase 9)."
spec:
  configOverrides:
    # CSV-batch flow (csv_to_bronze.py) schrijft Delta via deltalake-rs en
    # registreert de tabel daarna in HMS via `CALL bronze.system.register_table`.
    # Default disabled per Trino-security-best-practice; bewust enabled voor
    # bronze omdat dit de manier is waarop externe schrijvers (niet-Trino,
    # niet-Spark) zichzelf kenbaar maken aan de catalog.
    delta.register-table-procedure.enabled: "true"
  connector:
__TABLE_FORMAT_CONNECTOR_BLOCK__
