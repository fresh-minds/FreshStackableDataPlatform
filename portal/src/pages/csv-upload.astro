      display: flex;
      gap: var(--space-2);
      flex-wrap: wrap;
      margin: var(--space-4) 0 0;
    }

    .csv-layers {
      list-style: none;
      padding: 0;
      margin: 0 0 var(--space-5);
      display: flex;
      flex-direction: column;
      gap: var(--space-3);
    }
    .csv-layer {
      background: var(--bg-elev);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      padding: var(--space-3) var(--space-4);
    }
    .csv-layer-head {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      flex-wrap: wrap;
    }
    .csv-layer-tag {
      color: var(--ink-3);
      font-size: var(--text-eyebrow);
      letter-spacing: var(--tracking-eyebrow);
      min-width: 7ch;
    }
    .csv-table-btn {
      flex: 1 1 auto;
      display: inline-flex;
      align-items: baseline;
      justify-content: space-between;
      gap: var(--space-3);
      background: var(--bg-sunken);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      padding: 6px 10px;
      cursor: pointer;
      font: inherit;
      font-size: var(--text-meta);
      color: var(--ink-1);
      text-align: left;
      transition: border-color .15s, background .15s;
    }
    .csv-table-btn:hover {
      border-color: var(--ink-1);
      background: var(--bg-elev);
    }
    .csv-table-btn code {
      background: transparent;
      border: 0;
      padding: 0;
      color: var(--ink-1);
    }
    .csv-copy-hint {
      color: var(--ink-3);
      font-size: var(--text-eyebrow);
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
    }
    .csv-layer-note {
      color: var(--ink-2);
      font-size: var(--text-meta);
      margin: var(--space-2) 0 var(--space-1);
      line-height: var(--leading-body);
    }
    .csv-layer-meta {
      color: var(--ink-3);
      font-size: var(--text-eyebrow);
      letter-spacing: var(--tracking-eyebrow);
    }

    .csv-sql-h {
      font-size: var(--text-meta);
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eyebrow);
      color: var(--ink-3);
      font-weight: var(--weight-regular);
      margin: var(--space-5) 0 var(--space-2);
      border: 0;
      padding: 0;
    }

    .csv-copy-feedback {
      color: var(--ink-3);
      font-size: var(--text-meta);
      margin: var(--space-3) 0 0;
      min-height: 1.4em;
      opacity: 0;
      transform: translateY(-4px);
      transition: opacity .15s, transform .15s;
    }
    .csv-copy-feedback.csv-copy-feedback--on {
      opacity: 1;
      transform: translateY(0);
      color: var(--ink-1);
    }

    .csv-pre {
      background: var(--bg-sunken);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      padding: var(--space-3) var(--space-4);
      overflow-x: auto;
      margin: var(--space-2) 0;
      font-family: var(--font-mono);
      font-size: var(--text-meta);
      color: var(--ink-1);
    }
    .csv-pre code {
      background: transparent;
      padding: 0;
      border: 0;
    }

    .csv-alt summary,
    .csv-schema summary {
      cursor: pointer;
      color: var(--ink-3);
      font-size: var(--text-meta);
      list-style: none;
      padding: var(--space-2) 0;
    }
    .csv-alt summary::-webkit-details-marker,
    .csv-schema summary::-webkit-details-marker { display: none; }
    .csv-alt summary::before,
    .csv-schema summary::before {
      content: '▸';
      font-family: var(--font-mono);
      margin-right: var(--space-2);
      transition: transform .15s;
      display: inline-block;
    }
    .csv-alt[open] summary::before,
    .csv-schema[open] summary::before { transform: rotate(90deg); }
    .csv-alt summary:hover,
    .csv-schema summary:hover { color: var(--ink-1); }

    .csv-schema { margin: var(--space-3) 0 0; }
    .csv-schema-table {
      width: 100%;
      border-collapse: collapse;
      margin: var(--space-2) 0 0;
      background: var(--bg-elev);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      overflow: hidden;
      font-size: var(--text-meta);
    }
    .csv-schema-table th,
    .csv-schema-table td {
      padding: 6px var(--space-3);
      text-align: left;
      border-bottom: 1px solid var(--line-soft);
    }
    .csv-schema-table th {
      color: var(--ink-3);
      font-size: var(--text-eyebrow);
      letter-spacing: var(--tracking-eyebrow);
      text-transform: uppercase;
      font-weight: var(--weight-regular);
      background: var(--bg-sunken);
    }
    .csv-schema-table tr:last-child td { border-bottom: 0; }
    .csv-schema-table td.mono { color: var(--ink-1); }

    .csv-result {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      background: var(--bg-elev);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .csv-result li {
      display: grid;
      grid-template-columns: 12ch 1fr;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      border-bottom: 1px solid var(--line-soft);
      color: var(--ink-2);
      font-size: var(--text-meta);
    }
    .csv-result li:last-child { border-bottom: 0; }
    .csv-result li .mono {
      color: var(--ink-3);
      font-size: var(--text-eyebrow);
      letter-spacing: var(--tracking-eyebrow);
    }
    .csv-result em { font-style: italic; color: var(--ink-1); }
  </style>
</Layout>
