---
import Layout from '../layouts/Layout.astro';
import Button from '../components/primitives/Button.astro';
import Eyebrow from '../components/primitives/Eyebrow.astro';
import { docsArchitectureUrl } from '../data/external-links';

// Minimale CSV-upload UX. Wijst de gebruiker naar de twee externe stappen
// (MinIO Console upload + Airflow DAG-trigger) en toont een copy-pasteable
// `mc cp`-command voor wie liever via CLI werkt.
//
// Bewust geen browser-side multipart-upload: de portal is pure statische
// content (geen backend), dus we bouwen geen presigned-URL flow voor één
// demo-bron. Wanneer er meerdere CSV-bronnen komen kan dit een echte
// upload-form worden — bijvoorbeeld via MinIO STS + STS-token.

const sources = [
  {
    name: 'klanttevredenheid',
    title: 'Klanttevredenheid',
    description:
      'Klanttevredenheid-metingen per kanaal. Verwacht kolommen: meting_datum, ' +
      'kanaal, doelgroep, score (1–5), n_respondenten, opmerking.',
    bucket: 'uwv-staging',
    prefix: 'incoming/klanttevredenheid',
    dagId: 'ingest_csv_klanttevredenheid',
  },
];

const defaultSource = sources[0];
---
<Layout title="CSV upload">
  <section class="csv-hero">
    <Eyebrow rule>CSV-upload · staging</Eyebrow>
    <h1 class="csv-hero-title">
      Handmatige CSV-upload <em>naar bronze</em>.
    </h1>
    <p class="csv-hero-body">
      Upload een CSV-bestand voor een bron met <code>mode: csv_batch</code>.
      De flow is: bestand op MinIO zetten → Airflow-DAG triggeren →
      Delta-tabel in <code>bronze</code> → automatisch silver + gold via dbt.
    </p>
    <p class="csv-hero-note">
      Voor streaming-bronnen (WIA, WW, polisadministratie, …) gaat data via
      Kafka — zie de <a href={docsArchitectureUrl('ingestion')} target="_blank" rel="noopener noreferrer">architectuur-documentatie ↗</a>.
      CSV-upload is bedoeld voor ad-hoc batch-bronnen.
    </p>
  </section>

  <section class="csv-step">
    <Eyebrow>Bron</Eyebrow>
    <h2>Welke bron upload je?</h2>

    <div class="csv-pick">
      <label for="src-select">Kies een bron</label>
      <select id="src-select" aria-label="Bron">
        {sources.map((s) => (
          <option value={s.name}
                  data-bucket={s.bucket}
                  data-prefix={s.prefix}
                  data-dag={s.dagId}
                  data-desc={s.description}>
            {s.title}
          </option>
        ))}
      </select>
    </div>

    <p id="src-desc" class="csv-pick-desc">{defaultSource.description}</p>

    <dl class="csv-meta">
      <div class="csv-meta-row">
        <dt class="mono">BUCKET</dt>
        <dd><code id="src-bucket">{defaultSource.bucket}</code></dd>
      </div>
      <div class="csv-meta-row">
        <dt class="mono">PREFIX</dt>
        <dd><code id="src-prefix">{defaultSource.prefix}</code></dd>
      </div>
      <div class="csv-meta-row">
        <dt class="mono">DAG</dt>
        <dd><code id="src-dag">{defaultSource.dagId}</code></dd>
      </div>
    </dl>
  </section>

  <section class="csv-step">
    <Eyebrow>01 · Upload</Eyebrow>
    <h2>Zet het CSV-bestand op MinIO</h2>
    <p class="csv-step-body">
      Open MinIO Console en sleep je CSV in de map
      <code id="src-path-1">{defaultSource.bucket}/{defaultSource.prefix}/</code>.
      Naam mag vrij gekozen worden (bv. <code>2026-05-01.csv</code>).
    </p>
    <div class="csv-actions">
      <Button id="open-minio" variant="accent"
              href={`https://minio-console.uwv-platform.local:8443/browser/${defaultSource.bucket}/${defaultSource.prefix.replace(/\//g, '%2F')}%2F`}
              target="_blank" rel="noopener noreferrer">
        Open MinIO Console
      </Button>
    </div>
    <details class="csv-alt">
      <summary>Liever via CLI (<code>mc</code>)?</summary>
      <p class="csv-step-note">Stel éénmalig de alias in:</p>
      <pre class="csv-pre"><code>mc alias set minio-uwv https://minio.uwv-platform.local:8443 uwvadmin 'uwv-dev-only-CHANGE-ME-2026' --insecure</code></pre>
      <p class="csv-step-note">Daarna uploaden:</p>
      <pre class="csv-pre"><code id="mc-cmd">mc cp ./mijn-meting.csv minio-uwv/{defaultSource.bucket}/{defaultSource.prefix}/$(date -u +%Y%m%dT%H%M%S).csv --insecure</code></pre>
      <p class="csv-step-note">
        De DAG wordt automatisch getriggerd binnen 2 minuten — handmatige stap 2 is niet meer nodig.
      </p>
    </details>
  </section>

  <section class="csv-step">
    <Eyebrow>02 · Trigger</Eyebrow>
    <h2>Trigger de ingest-DAG in Airflow</h2>
    <p class="csv-step-body">
      Open Airflow en trigger DAG <code id="src-dag-2">{defaultSource.dagId}</code>
      met deze JSON-config (<em>Trigger DAG w/ config</em>):
    </p>
    <pre class="csv-pre"><code id="dag-conf">{JSON.stringify({ object_key: `${defaultSource.prefix}/<bestandsnaam>.csv` }, null, 2)}</code></pre>
    <div class="csv-actions">
      <Button id="open-airflow"
              href={`https://airflow.uwv-platform.local:8443/dags/${defaultSource.dagId}/`}
              target="_blank" rel="noopener noreferrer">
        Open Airflow DAG
      </Button>
    </div>
  </section>

  <section class="csv-step">
    <Eyebrow>03 · Resultaat</Eyebrow>
    <h2>Wat gebeurt er daarna?</h2>
    <ul class="csv-result">
      <li>
        <span class="mono">BRONZE</span>
        <span>Delta-tabel in <code>bronze.uwv.&lt;bron&gt;</code> (Trino).</span>
      </li>
      <li>
        <span class="mono">SILVER</span>
        <span>Getriggerd door bronze-Dataset; dbt staging-view.</span>
      </li>
      <li>
        <span class="mono">GOLD</span>
        <span>Getriggerd door silver-Dataset; dbt mart-tabel.</span>
      </li>
      <li>
        <span class="mono">SUPERSET</span>
        <span>Dashboard <em>Klanttevredenheid trend</em>.</span>
      </li>
    </ul>
    <div class="csv-actions">
      <Button href="https://trino.uwv-platform.local:8443" target="_blank" rel="noopener noreferrer">Trino UI</Button>
      <Button href="https://superset.uwv-platform.local:8443" target="_blank" rel="noopener noreferrer">Superset</Button>
      <Button href="https://openmetadata.uwv-platform.local:8443" target="_blank" rel="noopener noreferrer">OpenMetadata</Button>
    </div>
  </section>

  <script>
    const sel  = document.getElementById('src-select') as HTMLSelectElement | null;
    const desc = document.getElementById('src-desc');
    const buck = document.getElementById('src-bucket');
    const pref = document.getElementById('src-prefix');
    const dag  = document.getElementById('src-dag');
    const dag2 = document.getElementById('src-dag-2');
    const path1 = document.getElementById('src-path-1');
    const conf = document.getElementById('dag-conf');
    const mc   = document.getElementById('mc-cmd');
    const oM   = document.getElementById('open-minio') as HTMLAnchorElement | null;
    const oA   = document.getElementById('open-airflow') as HTMLAnchorElement | null;

    type Src = { description: string; bucket: string; prefix: string; dagId: string };
    const collected: Record<string, Src> = {};
    Array.from(sel?.options ?? []).forEach((opt) => {
      collected[opt.value] = {
        description: opt.dataset.desc   ?? '',
        bucket:      opt.dataset.bucket ?? '',
        prefix:      opt.dataset.prefix ?? '',
        dagId:       opt.dataset.dag    ?? '',
      };
    });

    function render() {
      const v = sel?.value;
      if (!v) return;
      const s = collected[v];
      if (desc) desc.textContent = s.description;
      if (buck) buck.textContent = s.bucket;
      if (pref) pref.textContent = s.prefix;
      if (dag)  dag.textContent  = s.dagId;
      if (dag2) dag2.textContent = s.dagId;
      if (path1) path1.textContent = `${s.bucket}/${s.prefix}/`;
      if (conf) conf.textContent = JSON.stringify({ object_key: `${s.prefix}/<bestandsnaam>.csv` }, null, 2);
      if (mc)   mc.textContent   = `mc cp ./mijn-meting.csv minio-uwv/${s.bucket}/${s.prefix}/$(date -u +%Y%m%dT%H%M%S).csv --insecure`;
      if (oM)   oM.href = `https://minio-console.uwv-platform.local:8443/browser/${s.bucket}/${encodeURIComponent(s.prefix + '/')}`;
      if (oA)   oA.href = `https://airflow.uwv-platform.local:8443/dags/${s.dagId}/`;
    }
    sel?.addEventListener('change', render);
    render();
  </script>

  <style>
    .csv-hero { padding: var(--space-9) 0 var(--space-7); max-width: 720px; }
    .csv-hero-title {
      font-size: 44px;
      line-height: var(--leading-display);
      letter-spacing: var(--tracking-display);
      font-weight: var(--weight-medium);
      color: var(--ink-1);
      margin: var(--space-4) 0 var(--space-4);
      border: 0;
      padding: 0;
      text-wrap: balance;
    }
    .csv-hero-title em {
      font-family: var(--font-serif);
      font-style: italic;
      color: var(--ink-3);
      font-weight: var(--weight-regular);
    }
    .csv-hero-body, .csv-hero-note {
      color: var(--ink-2);
      line-height: var(--leading-body);
      margin: 0 0 var(--space-3);
      max-width: 56ch;
    }
    .csv-hero-note { color: var(--ink-3); font-size: var(--text-meta); }
    .csv-hero code, .csv-step code {
      background: var(--bg-sunken);
      color: var(--ink-1);
      padding: 1px 6px;
      border-radius: 4px;
      border: 1px solid var(--line);
      font-size: 0.92em;
    }

    .csv-step {
      padding: var(--space-7) 0;
      border-top: 1px solid var(--line);
      max-width: 720px;
    }
    .csv-step h2 {
      font-size: var(--text-h2);
      font-weight: var(--weight-medium);
      letter-spacing: var(--tracking-tight);
      color: var(--ink-1);
      margin: var(--space-3) 0 var(--space-4);
      border: 0;
      padding: 0;
    }
    .csv-step-body, .csv-step-note {
      color: var(--ink-2);
      line-height: var(--leading-body);
      margin: 0 0 var(--space-4);
      text-wrap: pretty;
    }
    .csv-step-note { color: var(--ink-3); font-size: var(--text-meta); }

    .csv-pick {
      display: flex;
      align-items: center;
      gap: var(--space-3);
      margin-bottom: var(--space-3);
    }
    .csv-pick label {
      color: var(--ink-3);
      font-size: var(--text-meta);
      font-family: var(--font-mono);
      text-transform: uppercase;
      letter-spacing: var(--tracking-eyebrow);
    }
    .csv-pick select {
      background: var(--bg-elev);
      color: var(--ink-1);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      padding: 8px 12px;
      font: inherit;
      font-size: var(--text-meta);
    }
    .csv-pick-desc { color: var(--ink-3); margin: var(--space-2) 0 var(--space-4); font-size: var(--text-meta); }

    .csv-meta {
      display: flex;
      flex-direction: column;
      background: var(--bg-elev);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      margin: 0;
      overflow: hidden;
    }
    .csv-meta-row {
      display: grid;
      grid-template-columns: 14ch 1fr;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      border-bottom: 1px solid var(--line-soft);
    }
    .csv-meta-row:last-child { border-bottom: 0; }
    .csv-meta dt {
      color: var(--ink-3);
      font-size: var(--text-eyebrow);
      letter-spacing: var(--tracking-eyebrow);
      margin: 0;
    }
    .csv-meta dd { margin: 0; }

    .csv-actions {
      display: flex;
      gap: var(--space-2);
      flex-wrap: wrap;
      margin: var(--space-4) 0 0;
    }

    .csv-pre {
      background: var(--bg-sunken);
      border: 1px solid var(--line);
      border-radius: var(--radius-sm);
      padding: var(--space-3) var(--space-4);
      overflow-x: auto;
      margin: var(--space-2) 0;
      font-family: var(--font-mono);
      font-size: var(--text-meta);
      color: var(--ink-1);
    }
    .csv-pre code {
      background: transparent;
      padding: 0;
      border: 0;
    }

    .csv-alt summary {
      cursor: pointer;
      color: var(--ink-3);
      font-size: var(--text-meta);
      list-style: none;
      padding: var(--space-2) 0;
    }
    .csv-alt summary::-webkit-details-marker { display: none; }
    .csv-alt summary::before {
      content: '▸';
      font-family: var(--font-mono);
      margin-right: var(--space-2);
      transition: transform .15s;
      display: inline-block;
    }
    .csv-alt[open] summary::before { transform: rotate(90deg); }
    .csv-alt summary:hover { color: var(--ink-1); }

    .csv-result {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      background: var(--bg-elev);
      border: 1px solid var(--line);
      border-radius: var(--radius-md);
      overflow: hidden;
    }
    .csv-result li {
      display: grid;
      grid-template-columns: 12ch 1fr;
      align-items: center;
      gap: var(--space-3);
      padding: var(--space-3) var(--space-4);
      border-bottom: 1px solid var(--line-soft);
      color: var(--ink-2);
      font-size: var(--text-meta);
    }
    .csv-result li:last-child { border-bottom: 0; }
    .csv-result li .mono {
      color: var(--ink-3);
      font-size: var(--text-eyebrow);
      letter-spacing: var(--tracking-eyebrow);
    }
    .csv-result em { font-style: italic; color: var(--ink-1); }
  </style>
</Layout>
