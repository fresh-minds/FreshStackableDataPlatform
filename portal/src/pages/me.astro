---
import Layout from '../layouts/Layout.astro';
import ReferenceArchitecture from '../components/ReferenceArchitecture.astro';
import { roles, type RoleId } from '../data/roles';
import { components, stages } from '../data/components';
import { shortcuts } from '../data/role-shortcuts';
import roleMappings from '../data/role-mappings.generated.json';

// Bouw een client-side payload zodat de pagina puur statisch kan zijn:
// alle 11 rollen + componenten + shortcuts in één JSON, en de browser
// kiest op basis van Keycloak-claim of ?role=<id> wat zichtbaar wordt.

const capabilities = (roleMappings as { uwv_role_mappings: { roles: Record<string, unknown> } })
  .uwv_role_mappings.roles;

const payload = {
  roles,
  components,
  stages,
  shortcuts,
  capabilities,
};
---
<Layout title="Mijn werkplek">
  <section class="panel" id="role-picker" hidden>
    <h1>Kies een rol om te bekijken</h1>
    <p>
      Je bent niet ingelogd via Keycloak — dit is de demo-modus. Kies hieronder
      een rol om te zien wat die persoon op het platform mag doen. In
      productie wordt deze pagina automatisch ingevuld na SSO.
    </p>
    <div class="grid-3" id="picker-grid"></div>
  </section>

  <section class="panel" id="role-view" hidden>
    <header class="role-head">
      <div>
        <h1 id="rh-name">…</h1>
        <p id="rh-purpose" class="muted"></p>
      </div>
      <div class="role-meta">
        <span class="badge" id="rh-domain">…</span>
        <span class="badge" id="rh-category">…</span>
      </div>
    </header>

    <h2>Wat mag jij zien?</h2>
    <ul class="caps" id="caps-list"></ul>

    <h2>Snel naar je werk</h2>
    <div class="grid-2" id="shortcut-grid"></div>
  </section>

  <section class="panel" id="role-arch" hidden>
    <h2>Jouw plek in het platform</h2>
    <p class="muted">
      De componenten waar jij toegang toe hebt zijn opgelicht. De rest doet
      zijn werk op de achtergrond.
    </p>
    <div data-arch-host>
      <ReferenceArchitecture />
    </div>
  </section>

  <section class="panel" id="role-tools" hidden>
    <h2>Jouw tools</h2>
    <p class="muted">
      Gegroepeerd per laag. Klik om te openen — SSO regelt dat je niet opnieuw
      hoeft in te loggen.
    </p>
    <div id="tool-stages"></div>

    <details class="other-tools">
      <summary>Tools die je <em>niet</em> gebruikt — voor referentie</summary>
      <p class="muted">Toegang is geblokkeerd door OPA en Keycloak.</p>
      <div id="other-stages"></div>
    </details>
  </section>

  <section class="panel" id="role-help" hidden>
    <h2>Hulp en uitleg</h2>
    <ul>
      <li>
        <a id="help-handleiding" href="#">Lees jouw rol-handleiding</a>
        — workflows, foutmeldingen, escalatie.
      </li>
      <li><a href="/architecture/">Bekijk de architectuurkaart</a></li>
      <li>Mail <a href="mailto:data.steward@uwv-platform.local">data.steward@uwv-platform.local</a> bij vragen over data</li>
      <li>Bel platform-admin bij vermoede inbreuk (niet via mail)</li>
    </ul>

    <p>
      <a class="link-pick" href="/me/">← andere rol kiezen</a>
    </p>
  </section>

  <script type="application/json" id="me-data" set:html={JSON.stringify(payload)} />

  <script>
    interface RoleMeta { id: string; displayName: string; domain: string; category: string; handleidingPath: string; }
    interface Component {
      id: string; name: string; layer: string; stage: string;
      short: string; purpose: string; icon: string;
      url: string | null; prometheusJob?: string; rolesUsing: string[];
    }
    interface StageMeta { id: string; title: string; blurb: string; icon: string; kind: string; }
    interface Shortcut { title: string; hint: string; component: string; href: string; }
    interface Capability {
      catalogs: string[]; schemas: string[] | null; purposes: string[];
      can_see_pii: boolean; can_see_medical: boolean; can_see_bankrekening: boolean;
      regio_filter: boolean; break_glass: boolean;
      jit_required?: boolean; four_eyes_required?: boolean; _role_purpose?: string;
    }
    interface Payload {
      roles: RoleMeta[];
      components: Component[];
      stages: StageMeta[];
      shortcuts: Record<string, Shortcut[]>;
      capabilities: Record<string, Capability>;
    }

    const data: Payload = JSON.parse(
      document.getElementById('me-data')!.textContent ?? '{}',
    );

    function escape(s: string): string {
      return s.replace(/[&<>"']/g, (c) => ({
        '&':'&amp;', '<':'&lt;', '>':'&gt;', '"':'&quot;', "'":'&#39;',
      }[c]!));
    }

    function fmtBool(b: boolean, yes: string, no: string): string {
      return b ? `<span class="cap-yes">${yes}</span>` : `<span class="cap-no">${no}</span>`;
    }

    function pickerHtml(): string {
      return data.roles.map((r) => `
        <a class="role-card" href="?role=${r.id}">
          <strong>${escape(r.displayName)}</strong>
          <span>${escape(r.domain)}</span>
        </a>
      `).join('');
    }

    function showPicker() {
      const grid = document.getElementById('picker-grid')!;
      grid.innerHTML = pickerHtml();
      document.getElementById('role-picker')!.hidden = false;
      ['role-view','role-arch','role-tools','role-help'].forEach((id) => {
        document.getElementById(id)!.hidden = true;
      });
    }

    function renderToolCard(c: Component, emph: boolean): string {
      const isExternal = !!c.url && c.url.startsWith('http');
      const linkAttrs = c.url
        ? `href="${escape(c.url)}"${isExternal ? ' target="_blank" rel="noopener noreferrer"' : ''}`
        : 'href="#" onclick="return false;"';
      const title = `${escape(c.name)}${isExternal ? ' ↗' : ''}`;
      const status = c.prometheusJob
        ? `<span class="badge" data-status-job="${escape(c.prometheusJob)}"><span class="dot"></span></span>`
        : '';
      return `
        <a class="comp ${emph ? 'comp-emph' : ''}" ${linkAttrs} data-component="${escape(c.id)}">
          <header>
            <img class="comp-icon" src="${escape(c.icon)}" alt="" width="36" height="36" />
            <div class="comp-title">
              <h3>${title}</h3>
              <span class="comp-stage">${escape(c.stage)}</span>
            </div>
            ${status}
          </header>
          <p class="purpose">${escape(c.purpose)}</p>
          <p class="short">${escape(c.short)}</p>
          <footer><span class="layer">${escape(c.layer)}</span></footer>
        </a>`;
    }

    function renderStageGroup(
      stage: StageMeta,
      stageComps: Component[],
      emphasizeIds: Set<string>,
    ): string {
      if (stageComps.length === 0) return '';
      const cards = stageComps.map((c) => renderToolCard(c, emphasizeIds.has(c.id))).join('');
      return `
        <section class="stage-section" data-stage="${escape(stage.id)}">
          <header class="stage-section-head">
            <img class="stage-section-icon" src="${escape(stage.icon)}" alt="" width="28" height="28" />
            <div>
              <h3>${escape(stage.title)}</h3>
              <p>${escape(stage.blurb)}</p>
            </div>
          </header>
          <div class="grid-3">${cards}</div>
        </section>`;
    }

    function showRole(roleId: string) {
      const role = data.roles.find((r) => r.id === roleId);
      const cap = data.capabilities[roleId];
      if (!role || !cap) {
        showPicker();
        return;
      }

      ['role-view','role-arch','role-tools','role-help'].forEach((id) => {
        document.getElementById(id)!.hidden = false;
      });
      document.getElementById('role-picker')!.hidden = true;

      document.getElementById('rh-name')!.textContent = role.displayName;
      document.getElementById('rh-purpose')!.textContent = cap._role_purpose ?? '';
      document.getElementById('rh-domain')!.textContent = role.domain;
      document.getElementById('rh-category')!.textContent =
        role.category === 'tech' ? 'platform-team' : 'eindgebruiker';

      const handleiding = document.getElementById('help-handleiding') as HTMLAnchorElement;
      handleiding.href = `/${role.handleidingPath}`;

      // ─── Capabilities ───
      const caps: string[] = [];
      caps.push(`Catalogs: ${cap.catalogs.map((c) => `<code>${c}</code>`).join(', ')}`);
      if (cap.schemas) caps.push(`Schemas: ${cap.schemas.map((s) => `<code>${s}</code>`).join(', ')}`);
      caps.push(`Doelbinding(en): ${cap.purposes.map((p) => `<code>${p}</code>`).join(', ')}`);
      caps.push(`PII zien: ${fmtBool(cap.can_see_pii, 'ja', 'nee')}`);
      caps.push(`Medische data: ${fmtBool(cap.can_see_medical, 'ja', 'nee')}`);
      caps.push(`Bankrekening / IBAN: ${fmtBool(cap.can_see_bankrekening, 'ja', 'nee (gemaskeerd)')}`);
      caps.push(`Rij-filter regio: ${fmtBool(cap.regio_filter, 'ja, alleen jouw regio', 'nee')}`);
      if (cap.jit_required) caps.push('<span class="cap-warn">JIT-toegang vereist</span>');
      if (cap.four_eyes_required) caps.push('<span class="cap-warn">4-eyes vereist</span>');
      if (cap.break_glass) caps.push('<span class="cap-warn">Break-glass — alle handelingen gelogd</span>');
      document.getElementById('caps-list')!.innerHTML = caps.map((c) => `<li>${c}</li>`).join('');

      // ─── Shortcuts ───
      const sc = data.shortcuts[roleId] ?? [];
      document.getElementById('shortcut-grid')!.innerHTML = sc.length === 0
        ? '<p class="muted">Geen shortcuts gedefinieerd voor deze rol.</p>'
        : sc.map((s) => {
            const comp = data.components.find((c) => c.id === s.component);
            const stage = comp?.stage ?? '';
            const icon = comp?.icon ?? '';
            return `
              <a class="shortcut" href="${escape(s.href)}" target="_blank" rel="noopener noreferrer">
                ${icon ? `<img src="${escape(icon)}" alt="" width="28" height="28" />` : ''}
                <div class="shortcut-body">
                  <strong>${escape(s.title)}</strong>
                  <span class="hint">${escape(s.hint)}</span>
                  <span class="badge">${escape(comp?.name ?? s.component)} · ${escape(stage)}</span>
                </div>
              </a>`;
          }).join('');

      // ─── Tools per stage (mijn) en niet-mijn ───
      const myIds = new Set(
        data.components
          .filter((c) => c.rolesUsing.includes('*') || c.rolesUsing.includes(roleId))
          .map((c) => c.id),
      );

      const toolStagesEl  = document.getElementById('tool-stages')!;
      const otherStagesEl = document.getElementById('other-stages')!;
      const stageOrder = ['identity','ingestion','storage','transformation','consumption','discovery','pipeline','observability'];

      toolStagesEl.innerHTML = stageOrder.map((sid) => {
        const stage = data.stages.find((s) => s.id === sid);
        if (!stage) return '';
        const stageComps = data.components.filter((c) => c.stage === sid && myIds.has(c.id));
        return renderStageGroup(stage, stageComps, myIds);
      }).join('');

      otherStagesEl.innerHTML = stageOrder.map((sid) => {
        const stage = data.stages.find((s) => s.id === sid);
        if (!stage) return '';
        const stageComps = data.components.filter((c) => c.stage === sid && !myIds.has(c.id));
        return renderStageGroup(stage, stageComps, new Set());
      }).join('') || '<p class="muted">Je rol gebruikt alle componenten.</p>';

      // ─── Per-rol highlight in het reference-architecture diagram ───
      const arch = document.querySelector<HTMLElement>('[data-arch-host] .ref-arch');
      if (arch) {
        arch.dataset.activeRole = roleId;
        arch.querySelectorAll<HTMLElement>('[data-component]').forEach((el) => {
          const id = el.dataset.component!;
          el.classList.toggle('is-mine', myIds.has(id));
        });
      }

      refreshStatus();
    }

    async function refreshStatus() {
      const els = document.querySelectorAll<HTMLElement>('[data-status-job]');
      for (const el of els) {
        const job = el.dataset.statusJob!;
        try {
          const r = await fetch(`/api/status/up?job=${encodeURIComponent(job)}`, {
            credentials: 'include',
          });
          if (!r.ok) { el.classList.add('warn'); continue; }
          const j = await r.json();
          el.classList.remove('ok', 'warn', 'bad');
          if (j?.up === 1) el.classList.add('ok');
          else if (j?.up === 0) el.classList.add('bad');
          else el.classList.add('warn');
        } catch { el.classList.add('warn'); }
      }
    }

    function init() {
      // Voorrang: Keycloak-rol uit sessionStorage (gevuld door Layout.astro).
      // Daarna: ?role=… uit URL (demo-modus).
      const urlRole = new URLSearchParams(location.search).get('role');
      const ssoRole = sessionStorage.getItem('uwv-portal-role');
      const role = ssoRole || urlRole;
      if (role) showRole(role);
      else showPicker();
    }

    init();
    setInterval(refreshStatus, 30_000);
  </script>

  <style is:global>
    /* is:global zodat de regels ook gelden voor HTML die we via JS innerHTML
       injecteren — Astro's scoped styles werken alleen op template-content. */
    .role-head { display: flex; justify-content: space-between; gap: 1rem; align-items: flex-start; flex-wrap: wrap; margin-bottom: 1rem; }
    .role-head h1 { margin-bottom: .15rem; }
    .role-meta { display: flex; gap: .35rem; }
    .muted { color: var(--c-muted); }
    .caps { list-style: none; padding: 0; display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: .35rem .85rem; }
    .caps li { padding: .25rem 0; font-size: .9rem; border-bottom: 1px dashed var(--c-border); }
    .cap-yes { color: var(--c-ok); font-weight: 600; }
    .cap-no { color: var(--c-bad); font-weight: 600; }
    .cap-warn { color: var(--c-accent); font-weight: 600; }
    .role-card { display: flex; flex-direction: column; gap: .15rem; padding: .75rem .9rem; background: var(--c-panel-2); border: 1px solid var(--c-border); border-radius: var(--radius); color: var(--c-text); }
    .role-card:hover { border-color: var(--c-accent); text-decoration: none; }
    .role-card span { font-size: .8rem; color: var(--c-muted); }

    /* ─── Shortcuts (met icoon) ─── */
    .shortcut {
      display: grid;
      grid-template-columns: auto 1fr;
      gap: .65rem;
      padding: .85rem 1rem;
      background: var(--c-panel-2);
      border: 1px solid var(--c-border);
      border-radius: var(--radius);
      color: var(--c-text);
      align-items: center;
    }
    .shortcut:hover { border-color: var(--c-accent); text-decoration: none; }
    .shortcut img { display: block; }
    .shortcut-body { display: flex; flex-direction: column; gap: .15rem; min-width: 0; }
    .shortcut .hint { color: var(--c-muted); font-size: .82rem; }
    .shortcut .badge { align-self: flex-start; margin-top: .25rem; }

    /* ─── Stage-secties (klonen van StageSection.astro voor client-side render) ─── */
    .stage-section { margin-top: 1.25rem; }
    .stage-section-head {
      display: flex;
      gap: .75rem;
      align-items: flex-start;
      padding: .5rem .25rem .75rem;
      border-bottom: 1px solid var(--c-border);
      margin-bottom: .85rem;
    }
    .stage-section-icon { display: block; flex-shrink: 0; opacity: .85; margin-top: .15rem; }
    .stage-section-head h3 { margin: 0 0 .15rem; font-size: 1.05rem; }
    .stage-section-head p { margin: 0; color: var(--c-muted); font-size: .85rem; }

    /* ─── Component-card variant — moet matchen met ComponentCard.astro ─── */
    .comp {
      display: flex; flex-direction: column;
      gap: .4rem;
      background: var(--c-panel);
      border: 1px solid var(--c-border);
      border-radius: var(--radius);
      padding: .85rem 1rem;
      color: var(--c-text);
      transition: border-color .15s, transform .15s;
    }
    .comp:hover { border-color: var(--c-accent); text-decoration: none; transform: translateY(-1px); }
    .comp-emph { border-color: var(--c-accent); }
    .comp header {
      display: grid;
      grid-template-columns: auto 1fr auto;
      align-items: center;
      gap: .65rem;
    }
    .comp-icon { display: block; flex-shrink: 0; }
    .comp-title { display: flex; flex-direction: column; gap: .1rem; min-width: 0; }
    .comp h3 { margin: 0; font-size: .98rem; line-height: 1.2; }
    .comp-stage { font-size: .68rem; text-transform: uppercase; letter-spacing: .06em; color: var(--c-muted); }
    .purpose { margin: .25rem 0 0; color: var(--c-text); font-size: .85rem; line-height: 1.4; }
    .short { margin: 0; color: var(--c-muted); font-size: .78rem; line-height: 1.4; flex: 1; }
    .comp footer { font-size: .68rem; color: var(--c-muted); text-transform: uppercase; letter-spacing: .05em; margin-top: .35rem; }
    .layer { background: var(--c-panel-2); padding: .12rem .5rem; border-radius: 999px; }

    .other-tools { margin-top: 1.5rem; }
    .other-tools summary { cursor: pointer; color: var(--c-muted); padding: .5rem 0; }
    .other-tools summary:hover { color: var(--c-text); }

    .badge .dot { display: inline-block; width: .55em; height: .55em; border-radius: 50%; background: var(--c-muted); margin-right: .35em; vertical-align: middle; }
  </style>
</Layout>
