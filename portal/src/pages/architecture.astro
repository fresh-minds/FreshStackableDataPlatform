---
import Layout from '../layouts/Layout.astro';
import ReferenceArchitecture from '../components/ReferenceArchitecture.astro';
import StageSection from '../components/StageSection.astro';
import { components, stages, type ComponentStage } from '../data/components';

// Volgorde voor de gegroepeerde cards onder het diagram.
const cardStages: ComponentStage[] = [
  'identity',
  'ingestion',
  'storage',
  'transformation',
  'consumption',
  'discovery',
  'pipeline',
  'observability',
];
---
<Layout title="Architectuur">
  <section class="panel hero">
    <h1>Architectuur — referentie data-platform</h1>
    <p>
      Een data-platform bestaat uit een keten van lagen: data komt binnen
      (<em>ingestie</em>), wordt opgeslagen (<em>lakehouse</em>), bewerkt en
      gemodelleerd (<em>transformatie</em>) en uiteindelijk geconsumeerd in
      dashboards en data-producten. Daaroverheen liggen drie horizontale lagen:
      <strong>discovery</strong> (wat hebben we), <strong>pipeline</strong>
      (wat draait wanneer) en <strong>observability</strong> (gaat het goed).
    </p>
    <p class="note">
      Klik op een component om de UI te openen — SSO regelt dat je niet opnieuw
      hoeft in te loggen. De stip toont live <code>up{`{job=…}`}</code> uit
      Prometheus. Geïnspireerd op het
      <a href="https://www.montecarlodata.com/blog-what-is-a-data-platform-and-how-to-build-one/" target="_blank" rel="noopener noreferrer">Monte Carlo data-platform-model</a>.
    </p>
  </section>

  <ReferenceArchitecture />

  <section class="panel" style="margin-top:1.5rem">
    <h2>Componenten per laag</h2>
    <p>
      Live <code>up{`{job=...}`}</code> uit Prometheus. Stip wordt na een
      seconde groen/rood; blijft hij grijs, dan is Prometheus zelf niet
      bereikbaar of staat de portal in lokale dev.
    </p>

    <div class="comp-toolbar">
      <input id="comp-search" type="search" placeholder="Zoek component, laag of doel…"
             autocomplete="off" aria-label="Zoek componenten" />
      <span class="comp-counter" data-comp-counter></span>
    </div>

    <div id="stage-sections">
      {cardStages.map((id) => {
        const stage = stages.find((s) => s.id === id)!;
        const stageComps = components.filter((c) => c.stage === id);
        return <StageSection stage={stage} components={stageComps} />;
      })}
    </div>
  </section>

  <section class="panel">
    <h2>Datazones</h2>
    <p>
      Vier zones in MinIO + Hive: <code>bronze</code> (ruw, alleen data-engineers
      met JIT), <code>silver</code> (geconformeerd, primair domein-toegang),
      <code>gold</code> (marts voor BI), <code>sensitive</code> (art. 9 AVG,
      4-eyes) en <code>sandbox</code> (gepseudonimiseerd, voor researchers).
      Welke zone jij mag zien zie je op
      <a href="/me/">Mijn werkplek</a>.
    </p>
  </section>

  <script>
    // Live status badges. Eén fetch per component zodat we ook bij groot
    // aantal niet 13× tegelijk Prometheus bestoken — maar pas op dat we
    // dit alleen doen als de proxy bereikbaar is.
    async function refreshStatus() {
      const els = document.querySelectorAll<HTMLElement>('[data-status-job]');
      for (const el of els) {
        const job = el.dataset.statusJob!;
        try {
          const r = await fetch(`/api/status/up?job=${encodeURIComponent(job)}`, {
            credentials: 'include',
          });
          if (!r.ok) {
            el.classList.add('warn');
            continue;
          }
          const j = await r.json();
          const up = j?.up;
          el.classList.remove('ok', 'warn', 'bad');
          if (up === 1) {
            el.classList.add('ok');
            el.title = `up{job="${job}"} = 1`;
          } else if (up === 0) {
            el.classList.add('bad');
            el.title = `up{job="${job}"} = 0`;
          } else {
            el.classList.add('warn');
            el.title = `Geen data voor up{job="${job}"}`;
          }
        } catch {
          el.classList.add('warn');
        }
      }
    }

    refreshStatus();
    setInterval(refreshStatus, 30_000);

    // ─── Eenvoudige zoek/filter over de component-cards ───
    const search = document.getElementById('comp-search') as HTMLInputElement | null;
    const counter = document.querySelector<HTMLElement>('[data-comp-counter]');
    function applyFilter() {
      const q = (search?.value ?? '').trim().toLowerCase();
      const sections = document.querySelectorAll<HTMLElement>('.stage-section');
      let totalVisible = 0;
      sections.forEach((sec) => {
        let visibleInSection = 0;
        sec.querySelectorAll<HTMLElement>('.comp').forEach((card) => {
          const text = card.textContent?.toLowerCase() ?? '';
          const match = q.length === 0 || text.includes(q);
          card.style.display = match ? '' : 'none';
          if (match) visibleInSection++;
        });
        sec.style.display = visibleInSection > 0 ? '' : 'none';
        totalVisible += visibleInSection;
      });
      if (counter) {
        counter.textContent = q
          ? `${totalVisible} van ${document.querySelectorAll('.comp').length} componenten`
          : '';
      }
    }
    search?.addEventListener('input', applyFilter);
    applyFilter();
  </script>

  <style>
    .hero h1 { margin-bottom: .75rem; }
    .hero em { color: var(--c-accent-2); font-style: normal; font-weight: 600; }
    .hero strong { color: var(--c-text); }
    .note { font-size: .82rem; color: var(--c-muted); margin-top: .75rem; }

    .comp-toolbar {
      display: flex; align-items: center; gap: .75rem;
      margin: .5rem 0 .25rem;
      flex-wrap: wrap;
    }
    .comp-toolbar input {
      flex: 1; min-width: 220px;
      background: var(--c-panel-2);
      color: var(--c-text);
      border: 1px solid var(--c-border);
      border-radius: var(--radius);
      padding: .5rem .75rem;
      font: inherit;
    }
    .comp-toolbar input:focus { outline: none; border-color: var(--c-accent); }
    .comp-counter { color: var(--c-muted); font-size: .82rem; }
  </style>
</Layout>
