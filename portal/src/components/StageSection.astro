---
// Stage section: header + grid of ComponentCards. Used on /architecture and
// (cloned in JS) on /me. The is:global blocks here are mirrored in
// me.astro's renderStageGroup() so the JS-injected markup picks up the
// same styling.

import type { PlatformComponent, StageMeta } from '../data/components';
import ComponentCard from './ComponentCard.astro';
import Eyebrow from './primitives/Eyebrow.astro';

interface Props {
  stage: StageMeta;
  components: PlatformComponent[];
  emphasizeIds?: string[];
}

const { stage, components, emphasizeIds = [] } = Astro.props;
---
<section class={`stage-section ${stage.category ? `stage-section--cat-${stage.category}` : ''}`}
         id={stage.id}
         data-stage={stage.id}>
  <header class="stage-section-head">
    <Eyebrow rule>{stage.id}</Eyebrow>
    <h3>{stage.title}</h3>
    <p>{stage.blurb}</p>
  </header>
  <div class="stage-section-grid">
    {components.map((c) => (
      <ComponentCard component={c} emphasis={emphasizeIds.includes(c.id)} />
    ))}
  </div>
</section>

<style is:global>
  .stage-section { margin-top: var(--space-7); scroll-margin-top: 80px; }
  .stage-section-head {
    padding: var(--space-2) 0 var(--space-4);
    border-bottom: 1px solid var(--line);
    margin-bottom: var(--space-4);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }
  .stage-section-head h3 {
    margin: 0;
    font-size: var(--text-h2);
    font-weight: var(--weight-medium);
    letter-spacing: var(--tracking-tight);
    color: var(--ink-1);
    border: 0;
    padding: 0;
  }
  .stage-section-head p {
    margin: 0;
    color: var(--ink-3);
    font-size: var(--text-meta);
    max-width: 640px;
    text-wrap: pretty;
  }
  .stage-section-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: var(--space-3);
  }

  .stage-section--cat-discovery     .eyebrow { color: var(--cat-discovery); }
  .stage-section--cat-pipeline      .eyebrow { color: var(--cat-pipeline); }
  .stage-section--cat-observability .eyebrow { color: var(--cat-observability); }
  .stage-section--cat-identity      .eyebrow { color: var(--cat-identity); }
</style>
