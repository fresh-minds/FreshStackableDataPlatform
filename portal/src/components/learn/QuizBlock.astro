---
// Quiz-blok. Antwoorden staan in MDX-frontmatter (zie content/config.ts).
// Bewust geen anti-cheat: de antwoord-index is in de gerenderde HTML zichtbaar
// via data-correct. Doelgroep is UWV-medewerkers — eerlijk leren, geen exam.

interface Question {
  q: string;
  options: string[];
  correct: number;
  explain?: string;
}

interface Props {
  moduleKey: string;
  questions: Question[];
  certifies: boolean;
}

const { moduleKey, questions, certifies } = Astro.props;
---
<div class="quiz" data-quiz-key={moduleKey} data-certifies={String(certifies)}>
  {questions.map((q, qi) => (
    <fieldset class="quiz-q" data-correct={q.correct}>
      <legend>{qi + 1}. {q.q}</legend>
      <div class="quiz-options">
        {q.options.map((opt, oi) => (
          <label>
            <input type="radio" name={`q-${moduleKey}-${qi}`} value={oi} />
            <span>{opt}</span>
          </label>
        ))}
      </div>
      {q.explain && <p class="quiz-explain" hidden>{q.explain}</p>}
    </fieldset>
  ))}
  <div class="quiz-actions">
    <button type="button" data-quiz-submit>Controleer antwoorden</button>
    <span class="quiz-result" data-quiz-result></span>
  </div>
</div>

<style>
  .quiz-q { border: 1px solid var(--c-border); border-radius: var(--radius); padding: .65rem .85rem; margin: .65rem 0; }
  .quiz-q legend { padding: 0 .35rem; font-weight: 500; }
  .quiz-q.correct { border-color: var(--c-ok); }
  .quiz-q.wrong   { border-color: var(--c-bad); }
  .quiz-options { display: flex; flex-direction: column; gap: .35rem; padding: .35rem 0; }
  .quiz-options label { display: flex; gap: .5rem; align-items: flex-start; cursor: pointer; }
  .quiz-options input { margin-top: .25rem; }
  .quiz-explain { margin: .35rem 0 0; color: var(--c-muted); font-size: .85rem; }
  .quiz-explain.show { display: block; }
  .quiz-actions { display: flex; gap: .85rem; align-items: center; margin-top: .85rem; }
  .quiz-actions button {
    padding: 10px 14px;
    border: 1px solid var(--accent);
    background: var(--accent);
    color: var(--accent-ink);
    border-radius: var(--radius-sm);
    font-family: var(--font-sans);
    font-size: 13.5px;
    font-weight: var(--weight-medium);
    cursor: pointer;
    transition: filter .15s;
  }
  .quiz-actions button:hover { filter: brightness(1.06); }
  .quiz-result { color: var(--c-muted); font-size: .9rem; }
  .quiz-result.pass { color: var(--c-ok); }
  .quiz-result.fail { color: var(--c-bad); }
</style>

<script>
  import { setProgress } from '../../scripts/learn-progress';

  document.querySelectorAll<HTMLElement>('.quiz').forEach((quiz) => {
    const key = quiz.dataset.quizKey!;
    const certifies = quiz.dataset.certifies === 'true';
    const submit = quiz.querySelector<HTMLButtonElement>('[data-quiz-submit]')!;
    const result = quiz.querySelector<HTMLElement>('[data-quiz-result]')!;

    submit.addEventListener('click', () => {
      const qs = quiz.querySelectorAll<HTMLFieldSetElement>('.quiz-q');
      let ok = 0;
      qs.forEach((q) => {
        const correct = Number(q.dataset.correct);
        const checked = q.querySelector<HTMLInputElement>('input:checked');
        const picked = checked ? Number(checked.value) : -1;
        q.classList.remove('correct', 'wrong');
        const explain = q.querySelector<HTMLElement>('.quiz-explain');
        if (picked === correct) {
          q.classList.add('correct');
          ok++;
        } else if (picked >= 0) {
          q.classList.add('wrong');
        }
        if (explain) {
          explain.hidden = false;
          explain.classList.add('show');
        }
      });
      const total = qs.length;
      result.textContent = `${ok} van ${total} goed`;
      result.classList.remove('pass', 'fail');
      const pass = ok === total;
      result.classList.add(pass ? 'pass' : 'fail');
      if (pass) {
        setProgress(key, 'done');
        if (certifies) {
          // Trigger certificaat-event — wordt opgevangen op /learn/me.
          document.dispatchEvent(new CustomEvent('uwv-learn:cert', { detail: { key } }));
        }
      }
    });
  });
</script>
