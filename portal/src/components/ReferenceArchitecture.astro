---
// Reference architecture as horizontal swim-lanes (one row per stage).
//   ┌── 168 px lane label ──┬─ 4-column tile grid ────────────────────────┐
//   │ 01 · INGESTIE         │ [NiFi]   →  [Kafka]                          │
//   ├───────────────────────┼─────────────────────────────────────────────┤
//   │ 02 · OPSLAG           │ [MinIO]  →  [Hive]                           │
//   ├───────────────────────┼─────────────────────────────────────────────┤
//   │ DATA DISCOVERY        │ [OpenMetadata]   [dbt-docs]                  │  ← tinted lane
//   └───────────────────────┴─────────────────────────────────────────────┘
//
// Each tile preserves [data-component] for the /me/ role-highlight pass and
// [data-status-job] for the live status refresh script (src/scripts/status.ts).
//
// Pipeline-step and output stages render a subtle mono "→" between adjacent
// tiles. Category stages (discovery / pipeline / observability / identity)
// get a soft tinted background and a colored eyebrow — these are the
// cross-cutting layers, no arrows.

import { components, stages, type StageMeta, type PlatformComponent } from '../data/components';
import Tile from './primitives/Tile.astro';
import Eyebrow from './primitives/Eyebrow.astro';
import Tag from './primitives/Tag.astro';

// Order: main pipeline first, then cross-cutting lanes. Skip 'sources'
// because it has no components in the current data set.
const laneOrder: ReadonlyArray<string> = [
  'ingestion', 'storage', 'transformation', 'consumption',
  'discovery', 'pipeline', 'observability', 'identity',
];

interface Lane {
  stage: StageMeta;
  components: PlatformComponent[];
  isFlow: boolean;
  step?: number; // 1-based step number for pipeline-step + output lanes
}

const lanes: Lane[] = (() => {
  const out: Lane[] = [];
  let stepNum = 0;
  for (const id of laneOrder) {
    const stage = stages.find((s) => s.id === id);
    if (!stage) continue;
    const stageComps = components.filter((c) => c.stage === id);
    if (stageComps.length === 0) continue;
    const isFlow = stage.kind === 'pipeline-step' || stage.kind === 'output';
    const step = isFlow ? ++stepNum : undefined;
    out.push({ stage, components: stageComps, isFlow, step });
  }
  return out;
})();
---
<section class="ref-arch" aria-label="Reference architecture">
  {lanes.map((lane) => (
    <div class={`lane lane--${lane.stage.kind} ${lane.stage.category ? `lane--cat-${lane.stage.category}` : ''}`}
         data-stage={lane.stage.id}>
      <header class="lane-label">
        <Eyebrow rule={!!lane.stage.category}>
          {lane.step !== undefined && <span class="lane-step">{String(lane.step).padStart(2, '0')}</span>}
          <span>{lane.stage.title}</span>
        </Eyebrow>
        <p class="lane-blurb">{lane.stage.blurb}</p>
        {lane.stage.tags && lane.stage.tags.length > 0 && (
          <div class="lane-tags">
            {lane.stage.tags.map((t) => <Tag variant="mono">{t}</Tag>)}
          </div>
        )}
      </header>

      <div class={`lane-tiles ${lane.isFlow ? 'lane-tiles--flow' : 'lane-tiles--grid'}`}>
        {lane.isFlow
          ? lane.components.flatMap((c, i) => {
              const subLabel = c.layer.toUpperCase();
              const tile = (
                <Tile name={c.name}
                      subLabel={subLabel}
                      icon={c.icon}
                      href={c.url}
                      statusJob={c.prometheusJob}
                      componentId={c.id}
                      title={c.purpose} />
              );
              if (i === lane.components.length - 1) return [tile];
              return [tile, <span class="lane-arrow" aria-hidden="true">→</span>];
            })
          : lane.components.map((c) => (
              <Tile name={c.name}
                    subLabel={c.layer.toUpperCase()}
                    icon={c.icon}
                    href={c.url}
                    statusJob={c.prometheusJob}
                    componentId={c.id}
                    title={c.purpose} />
            ))
        }
      </div>
    </div>
  ))}
</section>

<style is:global>
  .ref-arch {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    overflow: hidden;
  }

  .lane {
    display: grid;
    grid-template-columns: 168px 1fr;
    gap: var(--space-7);
    padding: var(--space-5) var(--space-5);
    border-top: 1px solid var(--line);
    align-items: start;
  }
  .lane:first-child { border-top: 0; }

  /* Category lanes: soft tinted background + colored eyebrow. */
  .lane--cat-discovery     { background: color-mix(in oklch, var(--cat-discovery-soft)     45%, transparent); }
  .lane--cat-pipeline      { background: color-mix(in oklch, var(--cat-pipeline-soft)      45%, transparent); }
  .lane--cat-observability { background: color-mix(in oklch, var(--cat-observability-soft) 45%, transparent); }
  .lane--cat-identity      { background: color-mix(in oklch, var(--cat-identity-soft)      45%, transparent); }

  [data-theme="dark"] .lane--cat-discovery     { background: color-mix(in oklch, var(--cat-discovery)     8%, transparent); }
  [data-theme="dark"] .lane--cat-pipeline      { background: color-mix(in oklch, var(--cat-pipeline)      8%, transparent); }
  [data-theme="dark"] .lane--cat-observability { background: color-mix(in oklch, var(--cat-observability) 8%, transparent); }
  [data-theme="dark"] .lane--cat-identity      { background: color-mix(in oklch, var(--cat-identity)      8%, transparent); }

  .lane--cat-discovery     .eyebrow { color: var(--cat-discovery); }
  .lane--cat-pipeline      .eyebrow { color: var(--cat-pipeline); }
  .lane--cat-observability .eyebrow { color: var(--cat-observability); }
  .lane--cat-identity      .eyebrow { color: var(--cat-identity); }

  .lane-label {
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    min-width: 0;
  }
  .lane-step {
    font-feature-settings: 'tnum';
    color: var(--ink-2);
  }
  .lane-blurb {
    margin: 0;
    color: var(--ink-3);
    font-size: var(--text-meta);
    line-height: 1.45;
    text-wrap: pretty;
  }
  .lane-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-1);
    margin-top: var(--space-1);
  }

  .lane-tiles {
    min-width: 0;
  }
  .lane-tiles--flow {
    display: flex;
    flex-wrap: wrap;
    align-items: stretch;
    gap: var(--space-3);
  }
  .lane-tiles--flow .tile {
    flex: 1 1 200px;
    min-width: 0;
  }
  .lane-tiles--grid {
    display: grid;
    grid-template-columns: repeat(4, minmax(0, 1fr));
    gap: var(--space-3);
  }
  .lane-tiles--grid .tile {
    grid-column: span 1;
  }

  .lane-arrow {
    align-self: center;
    color: var(--ink-4);
    font-family: var(--font-mono);
    font-size: 14px;
    flex: 0 0 auto;
    user-select: none;
  }

  /* Per-role highlight pass. /me/ adds data-active-role on .ref-arch and
     toggles .is-mine on each tile based on rolesUsing. */
  .ref-arch[data-active-role] .tile { opacity: 0.4; transition: opacity .2s; }
  .ref-arch[data-active-role] .tile.is-mine {
    opacity: 1;
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  /* Responsive: stack label above tiles below ~720 px. */
  @media (max-width: 720px) {
    .lane {
      grid-template-columns: 1fr;
      gap: var(--space-3);
      padding: var(--space-4) var(--space-4);
    }
    .lane-tiles--grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
    .lane-arrow { display: none; }
  }
</style>
