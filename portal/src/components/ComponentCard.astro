---
import type { PlatformComponent } from '../data/components';
import StatusBadge from './StatusBadge.astro';

interface Props {
  component: PlatformComponent;
  emphasis?: boolean;
}
const { component, emphasis = false } = Astro.props;
const hasUrl = component.url !== null;
const isExternal = hasUrl && component.url!.startsWith('http');
---
<article class={`comp ${emphasis ? 'comp-emph' : ''}`} data-component={component.id}>
  <header>
    <img class="comp-icon" src={component.icon} alt="" width="36" height="36" />
    <div class="comp-title">
      <h3>
        {hasUrl ? (
          <a href={component.url} target={isExternal ? '_blank' : undefined}
             rel={isExternal ? 'noopener noreferrer' : undefined}>
            {component.name}{isExternal ? ' ↗' : ''}
          </a>
        ) : (
          <span>{component.name}</span>
        )}
      </h3>
      <span class="comp-stage">{component.stage}</span>
    </div>
    {component.prometheusJob && <StatusBadge job={component.prometheusJob} label="" />}
  </header>
  <p class="purpose">{component.purpose}</p>
  <p class="short">{component.short}</p>
  <footer>
    <span class="layer">{component.layer}</span>
  </footer>
</article>

<style>
  .comp {
    background: var(--c-panel);
    border: 1px solid var(--c-border);
    border-radius: var(--radius);
    padding: .85rem 1rem;
    display: flex; flex-direction: column;
    gap: .4rem;
    transition: border-color .15s, transform .15s;
  }
  .comp:hover { border-color: var(--c-accent); transform: translateY(-1px); }
  .comp-emph { border-color: var(--c-accent); }

  .comp header {
    display: grid;
    grid-template-columns: auto 1fr auto;
    align-items: center;
    gap: .65rem;
  }
  .comp-icon { display: block; flex-shrink: 0; }
  .comp-title { display: flex; flex-direction: column; gap: .1rem; min-width: 0; }
  .comp h3 { margin: 0; font-size: .98rem; line-height: 1.2; }
  .comp-stage {
    font-size: .68rem;
    text-transform: uppercase;
    letter-spacing: .06em;
    color: var(--c-muted);
  }

  .purpose {
    margin: .25rem 0 0;
    color: var(--c-text);
    font-size: .85rem;
    line-height: 1.4;
  }
  .short {
    margin: 0;
    color: var(--c-muted);
    font-size: .78rem;
    line-height: 1.4;
    flex: 1;
  }

  .comp footer {
    font-size: .68rem;
    color: var(--c-muted);
    text-transform: uppercase;
    letter-spacing: .05em;
    margin-top: .35rem;
  }
  .layer { background: var(--c-panel-2); padding: .12rem .5rem; border-radius: 999px; }
</style>
