---
import type { PlatformComponent } from '../data/components';
import StatusDot from './primitives/StatusDot.astro';
import Eyebrow from './primitives/Eyebrow.astro';
import Tag from './primitives/Tag.astro';

interface Props {
  component: PlatformComponent;
  emphasis?: boolean;
}
const { component, emphasis = false } = Astro.props;
const hasUrl = component.url !== null;
const isExternal = hasUrl && component.url!.startsWith('http');
---
<article class={`comp ${emphasis ? 'comp-emph' : ''}`} data-component={component.id}>
  <header class="comp-head">
    <span class="comp-icon-wrap">
      <img class="comp-icon" src={component.icon} alt="" width="24" height="24" />
    </span>
    <div class="comp-title">
      <Eyebrow>{component.layer}</Eyebrow>
      <h3>
        {hasUrl ? (
          <a href={component.url}
             target={isExternal ? '_blank' : undefined}
             rel={isExternal ? 'noopener noreferrer' : undefined}>
            {component.name}{isExternal && <span class="comp-ext"> ↗</span>}
          </a>
        ) : (
          <span>{component.name}</span>
        )}
      </h3>
    </div>
    {component.prometheusJob && <StatusDot job={component.prometheusJob} size="md" />}
  </header>
  <p class="comp-purpose">{component.purpose}</p>
  <p class="comp-short">{component.short}</p>
  <footer class="comp-foot">
    <Tag variant="mono">{component.stage}</Tag>
  </footer>
</article>

<style>
  .comp {
    background: var(--bg-elev);
    border: 1px solid var(--line);
    border-radius: var(--radius-md);
    padding: var(--space-5);
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
    transition: border-color .15s, transform .15s, box-shadow .15s;
  }
  .comp:hover {
    border-color: var(--ink-4);
    transform: translateY(-1px);
    box-shadow: var(--card-shadow-hover);
  }
  .comp-emph {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent);
  }

  .comp-head {
    display: grid;
    grid-template-columns: auto 1fr auto;
    gap: var(--space-3);
    align-items: center;
    margin-bottom: var(--space-1);
  }
  .comp-icon-wrap {
    width: 36px;
    height: 36px;
    background: var(--bg-sunken);
    border-radius: var(--radius-sm);
    display: inline-flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
  }
  .comp-icon { display: block; }
  .comp-title {
    display: flex;
    flex-direction: column;
    gap: 1px;
    min-width: 0;
  }
  .comp h3 {
    margin: 0;
    font-size: var(--text-h3);
    font-weight: var(--weight-medium);
    color: var(--ink-1);
    line-height: 1.2;
    letter-spacing: var(--tracking-tight);
    border: 0;
    padding: 0;
  }
  .comp h3 a { color: var(--ink-1); text-decoration: none; }
  .comp h3 a:hover { color: var(--ink-1); }
  .comp-ext {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-3);
  }

  .comp-purpose {
    margin: 0;
    color: var(--ink-1);
    font-size: var(--text-meta);
    line-height: var(--leading-tight);
  }
  .comp-short {
    margin: 0;
    color: var(--ink-3);
    font-size: var(--text-meta);
    line-height: var(--leading-tight);
    flex: 1;
  }
  .comp-foot {
    display: flex;
    gap: var(--space-2);
    margin-top: var(--space-2);
  }
</style>
