---
interface Props {
  title: string;
  description?: string;
}

const { title, description = 'UWV Reference Data Platform — rol-aware launchpad' } = Astro.props;
---
<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="referrer" content="same-origin" />
    <title>{title} · UWV Platform Portal</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      // Voorkom flash-of-wrong-theme: zet data-theme vóór de body laadt.
      (function () {
        try {
          var saved = localStorage.getItem('uwv-portal-theme');
          var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          var theme = saved ?? (prefersLight ? 'light' : 'dark');
          document.documentElement.dataset.theme = theme;
        } catch (e) { /* localStorage onbeschikbaar — gebruik default */ }
      })();
    </script>
    <script is:inline>
      // Cross-environment URL rewrite: dezelfde Astro-build serveert k3d
      // (*.uwv-platform.local op host 8443) én AKS (*.uwv-platform.cloud).
      // Component- en shortcut-URLs zijn build-time hardcoded op .local;
      // als we op .cloud zitten herschrijven we ze ter plekke.
      (function () {
        var host = window.location.hostname;
        if (!host.endsWith('.uwv-platform.cloud')) return;
        function rewrite() {
          var anchors = document.querySelectorAll('a[href*="uwv-platform.local"]');
          for (var i = 0; i < anchors.length; i++) {
            anchors[i].href = anchors[i].href.replace(/uwv-platform\.local/g, 'uwv-platform.cloud');
          }
        }
        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', rewrite);
        } else {
          rewrite();
        }
        // Architecture/me/role pages render some links via client-side JS;
        // a single MutationObserver catches those without per-page hooks.
        new MutationObserver(rewrite).observe(document.documentElement, { childList: true, subtree: true });
      })();
    </script>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/">UWV <span>Platform Portal</span></a>
        <nav>
          <a href="/">Home</a>
          <a href="/architecture/">Architectuur</a>
          <a href="/me/">Mijn werkplek</a>
        </nav>
        <button class="theme-toggle" type="button" data-theme-toggle aria-label="Schakel thema">
          <svg class="theme-icon icon-sun"  width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4 7 17M17 7l1.4-1.4"/></svg>
          <svg class="theme-icon icon-moon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
        </button>
        <div class="who" data-who>
          <span class="who-label">Niet ingelogd</span>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer>
      <p>
        Referentie-implementatie · synthetische data · zie
        <a href="/UWV_Platform_Handboek_per_rol.pdf">handboek</a>
        of de
        <a href="https://github.com/" rel="noreferrer">repo</a>.
      </p>
    </footer>

    <script>
      // Probeer oauth2-proxy /oauth2/userinfo. Lukt het? Dan tonen we
      // de rol in de topbar. Lukt het niet (lokale dev zonder proxy),
      // dan blijven we op "Niet ingelogd" staan en mag de gebruiker
      // op /me een rol kiezen.
      async function loadIdentity() {
        try {
          const r = await fetch('/oauth2/userinfo', { credentials: 'include' });
          if (!r.ok) return;
          const me = await r.json();
          const groups: string[] = me.groups ?? me.roles ?? [];
          const known = [
            'wia_beoordelaar','ww_handhaver','wajong_arbeidsdeskundige','crm_medewerker',
            'fez_analist','smz_planner','proactief_dienstverlener','researcher',
            'data_steward','data_engineer','platform_admin',
          ];
          const role = groups.find((g) => known.includes(g)) ?? null;
          if (role) {
            sessionStorage.setItem('uwv-portal-role', role);
            sessionStorage.setItem('uwv-portal-user', me.email ?? me.user ?? 'onbekend');
          }
          renderWho();
        } catch {
          /* niet ingelogd / lokale dev */
        }
      }

      function renderWho() {
        const el = document.querySelector<HTMLElement>('[data-who]');
        if (!el) return;
        const role = sessionStorage.getItem('uwv-portal-role');
        const user = sessionStorage.getItem('uwv-portal-user');
        if (role) {
          el.innerHTML = `
            <span class="who-role">${role}</span>
            <span class="who-user">${user ?? ''}</span>
            <a class="who-logout" href="#" onclick="sessionStorage.removeItem('uwv-portal-role');sessionStorage.removeItem('uwv-portal-user');const rd=encodeURIComponent('https://keycloak.uwv-platform.local:8443/realms/uwv/protocol/openid-connect/logout?client_id=portal&post_logout_redirect_uri=https://platform.uwv-platform.local:8443/');window.location.href='/oauth2/sign_out?rd='+rd;return false;">uitloggen</a>
          `;
        }
      }

      // ─── Thema-toggle ───
      const toggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
      toggle?.addEventListener('click', () => {
        const cur = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
        const next = cur === 'light' ? 'dark' : 'light';
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('uwv-portal-theme', next); } catch {}
      });

      renderWho();
      loadIdentity();
    </script>

    <style is:global>
      :root {
        --radius: 6px;
        --max-w: 1280px;
        font-family: ui-sans-serif, system-ui, -apple-system, "Segoe UI", Roboto, sans-serif;
      }

      /* Donker thema (default). */
      :root, [data-theme="dark"] {
        --c-bg: #0e1116;
        --c-panel: #161b22;
        --c-panel-2: #1f262d;
        --c-border: #30363d;
        --c-text: #e6edf3;
        --c-muted: #9ba6b1;
        --c-accent: #f59e0b;
        --c-accent-2: #fbbf24;
        --c-link: #79c0ff;
        --c-ok: #3fb950;
        --c-warn: #d29922;
        --c-bad: #f85149;
        color-scheme: dark;
      }

      /* Licht thema. */
      [data-theme="light"] {
        --c-bg: #f7f8fa;
        --c-panel: #ffffff;
        --c-panel-2: #eef1f5;
        --c-border: #d0d7de;
        --c-text: #1f2328;
        --c-muted: #57606a;
        --c-accent: #b45309;
        --c-accent-2: #92400e;
        --c-link: #0969da;
        --c-ok: #1a7f37;
        --c-warn: #9a6700;
        --c-bad: #cf222e;
        color-scheme: light;
      }

      * { box-sizing: border-box; }
      html, body { margin: 0; padding: 0; background: var(--c-bg); color: var(--c-text); }
      a { color: var(--c-link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2, h3 { line-height: 1.25; margin-top: 0; }
      h1 { font-size: 1.75rem; }
      h2 { font-size: 1.25rem; border-bottom: 1px solid var(--c-border); padding-bottom: .35rem; }
      h3 { font-size: 1rem; }
      code { font-family: ui-monospace, SFMono-Regular, Menlo, monospace; background: var(--c-panel-2); padding: .1em .3em; border-radius: 4px; }

      .topbar {
        background: var(--c-panel);
        border-bottom: 1px solid var(--c-border);
        position: sticky; top: 0; z-index: 10;
      }
      .topbar-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: .75rem 1rem;
        display: flex; align-items: center; gap: 1.25rem;
      }
      .brand { font-weight: 600; color: var(--c-text); font-size: 1.05rem; }
      .brand span { color: var(--c-accent); font-weight: 500; }
      nav { display: flex; gap: 1rem; flex: 1; }
      nav a { color: var(--c-muted); }
      nav a:hover { color: var(--c-text); text-decoration: none; }
      .who { font-size: .85rem; color: var(--c-muted); display: flex; gap: .5rem; align-items: center; }
      .who-role { background: var(--c-accent); color: #1a1206; padding: .15rem .5rem; border-radius: 999px; font-weight: 600; }
      [data-theme="light"] .who-role { color: #fff; }
      .who-user { font-style: italic; }
      .who-logout { color: var(--c-muted); font-size: .8rem; }

      .theme-toggle {
        background: transparent;
        border: 1px solid var(--c-border);
        border-radius: var(--radius);
        color: var(--c-muted);
        cursor: pointer;
        padding: .35rem .5rem;
        display: inline-flex;
        align-items: center;
        justify-content: center;
      }
      .theme-toggle:hover { color: var(--c-text); border-color: var(--c-accent); }
      .theme-icon { display: none; }
      [data-theme="dark"] .theme-toggle .icon-sun { display: block; }
      [data-theme="light"] .theme-toggle .icon-moon { display: block; }

      main { max-width: var(--max-w); margin: 0 auto; padding: 1.5rem 1rem 3rem; }
      footer { text-align: center; color: var(--c-muted); font-size: .8rem; padding: 1rem; border-top: 1px solid var(--c-border); }

      .panel { background: var(--c-panel); border: 1px solid var(--c-border); border-radius: var(--radius); padding: 1rem 1.25rem; margin-bottom: 1rem; }
      .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
      .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: .75rem; }

      .badge { display: inline-block; font-size: .7rem; padding: .15rem .5rem; border-radius: 999px; background: var(--c-panel-2); color: var(--c-muted); border: 1px solid var(--c-border); }
      .badge.ok   { background: color-mix(in srgb, var(--c-ok) 18%, transparent);   color: var(--c-ok);   border-color: color-mix(in srgb, var(--c-ok) 45%, transparent); }
      .badge.warn { background: color-mix(in srgb, var(--c-warn) 18%, transparent); color: var(--c-warn); border-color: color-mix(in srgb, var(--c-warn) 45%, transparent); }
      .badge.bad  { background: color-mix(in srgb, var(--c-bad) 18%, transparent);  color: var(--c-bad);  border-color: color-mix(in srgb, var(--c-bad) 45%, transparent); }
    </style>
  </body>
</html>
