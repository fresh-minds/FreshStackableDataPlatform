---
import '@fontsource-variable/inter';
import '@fontsource-variable/jetbrains-mono';
import '../styles/tokens.css';
import '../styles/base.css';

import NavLink from '../components/primitives/NavLink.astro';
import UserPill from '../components/primitives/UserPill.astro';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'UWV Reference Data Platform — rol-aware launchpad' } = Astro.props;

// Active-state for nav links — strip trailing slash to compare cleanly.
const path = Astro.url.pathname.replace(/\/$/, '') || '/';
const isActive = (href: string): boolean => {
  const stripped = href.replace(/\/$/, '') || '/';
  if (stripped === '/') return path === '/';
  return path === stripped || path.startsWith(stripped + '/');
};
---
<!DOCTYPE html>
<html lang="nl">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <meta name="referrer" content="same-origin" />
    <title>{title} · UWV Platform Portal</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <script is:inline>
      // Voorkom flash-of-wrong-theme: zet data-theme vóór de body laadt.
      (function () {
        try {
          var saved = localStorage.getItem('uwv-portal-theme');
          var prefersLight = window.matchMedia('(prefers-color-scheme: light)').matches;
          var theme = saved ?? (prefersLight ? 'light' : 'dark');
          document.documentElement.dataset.theme = theme;
        } catch (e) { /* localStorage onbeschikbaar — gebruik default */ }
      })();
    </script>
    <script is:inline>
      // Cross-environment URL rewrite. The same Astro build serves k3d
      // (*.uwv-platform.local on host:8443) and AKS public DNS
      // (eu-sovereigndataplatform.com + *.eu-sovereigndataplatform.com on
      // standard 443). Component-, role-shortcut, and academy-MDX hrefs
      // are build-time hardcoded as https://<svc>.uwv-platform.local:8443;
      // on the .com host we rewrite to https://<svc>.eu-sovereigndataplatform.com
      // (drop the :8443 — public LB is on 443).
      (function () {
        var host = window.location.hostname;
        if (host !== 'eu-sovereigndataplatform.com' &&
            !host.endsWith('.eu-sovereigndataplatform.com')) return;

        function rewriteHref(href) {
          return href
            .replace(/:\/\/([a-z0-9-]+)\.uwv-platform\.local(:8443)?/g,
                     '://$1.eu-sovereigndataplatform.com');
        }

        function rewrite() {
          var anchors = document.querySelectorAll('a[href*="uwv-platform.local"]');
          for (var i = 0; i < anchors.length; i++) {
            var a = anchors[i];
            // Don't touch mailto / tel / etc. — only http(s) URLs.
            if (!/^https?:\/\//i.test(a.href)) continue;
            a.href = rewriteHref(a.href);
          }
        }

        if (document.readyState === 'loading') {
          document.addEventListener('DOMContentLoaded', rewrite);
        } else {
          rewrite();
        }
        // Catch dynamically-rendered links (status badges, role-shortcut JS).
        new MutationObserver(rewrite).observe(document.documentElement,
          { childList: true, subtree: true });

        // Final safety net: even if the MutationObserver misses (e.g. an
        // anchor whose href is set programmatically right before a click),
        // intercept the click and rewrite once more.
        document.addEventListener('click', function (ev) {
          var a = ev.target && ev.target.closest && ev.target.closest('a[href*="uwv-platform.local"]');
          if (a && /^https?:\/\//i.test(a.href)) a.href = rewriteHref(a.href);
        }, true);
      })();
    </script>
  </head>
  <body>
    <header class="topbar">
      <div class="topbar-inner">
        <a class="brand" href="/" aria-label="UWV Platform Portal">
          <span class="brand-mark" aria-hidden="true">UWV</span>
          <span class="brand-name"><b>Platform</b> <span class="brand-name-suffix">Portal</span></span>
        </a>

        <nav class="topbar-nav" aria-label="Hoofdnavigatie">
          <NavLink href="/" active={isActive('/')}>Home</NavLink>
          <NavLink href="/architecture/" active={isActive('/architecture/')}>Architectuur</NavLink>
          <NavLink href="/me/" active={isActive('/me/')}>Mijn werkplek</NavLink>
          <NavLink href="/learn/" active={isActive('/learn/')}>Academy</NavLink>
        </nav>

        <div class="topbar-right">
          <button class="theme-toggle" type="button" data-theme-toggle aria-label="Schakel thema">
            <svg class="theme-icon icon-sun"  width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="12" cy="12" r="4"/><path d="M12 3v2M12 19v2M3 12h2M19 12h2M5.6 5.6l1.4 1.4M17 17l1.4 1.4M5.6 18.4 7 17M17 7l1.4-1.4"/></svg>
            <svg class="theme-icon icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M21 12.8A9 9 0 1 1 11.2 3a7 7 0 0 0 9.8 9.8z"/></svg>
          </button>
          <UserPill />
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="site-footer">
      <div class="site-footer-inner">
        <span class="mono">Referentie-implementatie · synthetische data</span>
        <span class="site-footer-links">
          <a href="/UWV_Platform_Handboek_per_rol.pdf">Handboek</a>
          <span aria-hidden="true">·</span>
          <a href="https://github.com/" rel="noreferrer">Repo</a>
          <span aria-hidden="true">·</span>
          <a href="/styleguide/">Styleguide</a>
        </span>
      </div>
    </footer>

    <script>
      // Probeer oauth2-proxy /oauth2/userinfo. Lukt het? Dan tonen we
      // de rol in de topbar. Lukt het niet (lokale dev zonder proxy),
      // dan blijven we op "Niet ingelogd" staan en mag de gebruiker
      // op /me een rol kiezen.
      async function loadIdentity() {
        try {
          const r = await fetch('/oauth2/userinfo', { credentials: 'include' });
          if (!r.ok) return;
          const me = await r.json();
          const groups: string[] = me.groups ?? me.roles ?? [];
          const known = [
            'wia_beoordelaar','ww_handhaver','wajong_arbeidsdeskundige','crm_medewerker',
            'fez_analist','smz_planner','proactief_dienstverlener','researcher',
            'data_steward','data_engineer','platform_admin',
          ];
          const role = groups.find((g) => known.includes(g)) ?? null;
          if (role) {
            sessionStorage.setItem('uwv-portal-role', role);
            sessionStorage.setItem('uwv-portal-user', me.email ?? me.user ?? 'onbekend');
          }
          renderWho();
        } catch {
          /* niet ingelogd / lokale dev */
        }
      }

      function escapeHtml(s: string): string {
        return s.replace(/[&<>"']/g, (c) => ({
          '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;',
        }[c]!));
      }

      function renderWho() {
        const el = document.querySelector<HTMLElement>('[data-who]');
        if (!el) return;
        const role = sessionStorage.getItem('uwv-portal-role');
        const user = sessionStorage.getItem('uwv-portal-user');
        if (!role) return;

        const initial = ((user ?? role).trim().charAt(0) || '?').toUpperCase();
        el.classList.remove('user-pill--empty');
        // Markup mirrors UserPill primitive's loaded state.
        // The logout onclick is TLD-aware: the same build serves k3d
        // (uwv-platform.local:8443) and AKS public DNS
        // (eu-sovereigndataplatform.com on 443). Pick the right host.
        el.innerHTML = `
          <span class="user-pill-avatar" aria-hidden="true">${escapeHtml(initial)}</span>
          <span class="user-pill-body">
            <span class="user-pill-role">${escapeHtml(role)}</span>
            <span class="user-pill-user" title="${escapeHtml(user ?? '')}">${escapeHtml(user ?? '')}</span>
          </span>
          <a class="user-pill-logout" href="#" title="uitloggen" aria-label="uitloggen" onclick="sessionStorage.removeItem('uwv-portal-role');sessionStorage.removeItem('uwv-portal-user');var h=location.hostname,tld='uwv-platform.local',port=':8443';if(h.endsWith('.eu-sovereigndataplatform.com')){tld='eu-sovereigndataplatform.com';port='';}const rd=encodeURIComponent('https://keycloak.'+tld+port+'/realms/uwv/protocol/openid-connect/logout?client_id=portal&post_logout_redirect_uri=https://platform.'+tld+port+'/');window.location.href='/oauth2/sign_out?rd='+rd;return false;">↗</a>
        `;
      }

      // ─── Thema-toggle ───
      const toggle = document.querySelector<HTMLButtonElement>('[data-theme-toggle]');
      toggle?.addEventListener('click', () => {
        const cur = document.documentElement.dataset.theme === 'light' ? 'light' : 'dark';
        const next = cur === 'light' ? 'dark' : 'light';
        document.documentElement.dataset.theme = next;
        try { localStorage.setItem('uwv-portal-theme', next); } catch {}
      });

      renderWho();
      loadIdentity();
    </script>

    <style is:global>
      /* Tokens, fonts, and resets are imported from src/styles/* in
         this file's frontmatter. The rules below cover global page
         elements (links, headings, code) plus the layout chrome
         (topbar / footer / panel / badge / grid utilities). */

      a { color: var(--c-link); text-decoration: none; }
      a:hover { text-decoration: underline; }
      h1, h2, h3 { line-height: 1.25; margin-top: 0; }
      h1 { font-size: 1.75rem; }
      h2 { font-size: 1.25rem; border-bottom: 1px solid var(--c-border); padding-bottom: .35rem; }
      h3 { font-size: 1rem; }
      code { font-family: var(--font-mono); background: var(--c-panel-2); padding: .1em .3em; border-radius: 4px; font-size: 0.92em; }

      /* ─── Topbar ─── */
      .topbar {
        background: color-mix(in oklch, var(--bg-elev) 92%, transparent);
        backdrop-filter: saturate(140%) blur(8px);
        -webkit-backdrop-filter: saturate(140%) blur(8px);
        border-bottom: 1px solid var(--line);
        position: sticky;
        top: 0;
        z-index: 10;
      }
      .topbar-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: 12px var(--page-padx);
        display: grid;
        grid-template-columns: auto 1fr auto;
        align-items: center;
        gap: var(--space-7);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3);
        color: var(--ink-1);
        text-decoration: none;
        font-size: var(--text-meta);
      }
      .brand:hover { text-decoration: none; }
      .brand-mark {
        width: 26px;
        height: 26px;
        border-radius: var(--radius-sm);
        background: var(--accent);
        color: var(--accent-ink);
        display: inline-flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-sans);
        font-weight: var(--weight-bold);
        font-size: 9px;
        letter-spacing: 0.04em;
        flex-shrink: 0;
      }
      .brand-name { line-height: 1; }
      .brand-name b { font-weight: var(--weight-semibold); color: var(--ink-1); }
      .brand-name-suffix { color: var(--ink-3); font-weight: var(--weight-regular); }

      .topbar-nav {
        display: flex;
        gap: var(--space-1);
        justify-self: start;
      }
      .topbar-right {
        display: inline-flex;
        align-items: center;
        gap: var(--space-3);
      }

      /* ─── Theme toggle: 32px bordered icon button ─── */
      .theme-toggle {
        width: 32px;
        height: 32px;
        border: 1px solid var(--line);
        border-radius: var(--radius-sm);
        background: var(--bg-elev);
        color: var(--ink-2);
        cursor: pointer;
        display: inline-flex;
        align-items: center;
        justify-content: center;
        padding: 0;
        flex-shrink: 0;
        transition: background 0.15s, border-color 0.15s, color 0.15s;
      }
      .theme-toggle:hover {
        background: var(--bg-sunken);
        color: var(--ink-1);
      }
      .theme-icon { display: none; }
      [data-theme="dark"] .theme-toggle .icon-sun { display: block; }
      [data-theme="light"] .theme-toggle .icon-moon { display: block; }

      /* ─── Main + footer ─── */
      main {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: var(--space-7) var(--page-padx) var(--space-11);
      }
      .site-footer {
        border-top: 1px solid var(--line);
        margin-top: var(--space-9);
      }
      .site-footer-inner {
        max-width: var(--max-w);
        margin: 0 auto;
        padding: var(--space-5) var(--page-padx);
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: var(--space-5);
        color: var(--ink-3);
        font-size: var(--text-meta);
        flex-wrap: wrap;
      }
      .site-footer-links {
        display: inline-flex;
        gap: var(--space-3);
        align-items: center;
      }
      .site-footer-inner a { color: var(--ink-3); }
      .site-footer-inner a:hover { color: var(--ink-1); }

      /* ─── Legacy chrome — kept until pages are individually migrated ─── */
      .panel { background: var(--c-panel); border: 1px solid var(--c-border); border-radius: var(--radius); padding: 1rem 1.25rem; margin-bottom: 1rem; }
      .grid-2 { display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 1rem; }
      .grid-3 { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: .75rem; }

      .badge { display: inline-block; font-size: .7rem; padding: .15rem .5rem; border-radius: 999px; background: var(--c-panel-2); color: var(--c-muted); border: 1px solid var(--c-border); }
      .badge.ok   { background: color-mix(in srgb, var(--c-ok) 18%, transparent);   color: var(--c-ok);   border-color: color-mix(in srgb, var(--c-ok) 45%, transparent); }
      .badge.warn { background: color-mix(in srgb, var(--c-warn) 18%, transparent); color: var(--c-warn); border-color: color-mix(in srgb, var(--c-warn) 45%, transparent); }
      .badge.bad  { background: color-mix(in srgb, var(--c-bad) 18%, transparent);  color: var(--c-bad);  border-color: color-mix(in srgb, var(--c-bad) 45%, transparent); }

      /* ─── Responsive: collapse topbar grid below ~720px ─── */
      @media (max-width: 720px) {
        .topbar-inner {
          grid-template-columns: 1fr auto;
          gap: var(--space-3);
          padding: 10px var(--space-4);
        }
        .topbar-nav { grid-column: 1 / -1; flex-wrap: wrap; }
        .brand-name-suffix { display: none; }
      }
    </style>
  </body>
</html>
