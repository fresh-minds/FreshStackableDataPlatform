# Source this file before running any AKS / terraform commands:
#   source scripts/azure/env.sh
#
# Copy from env.sh.example and fill in the secret. The actual env.sh is gitignored.

# Service principal (sp_stackable)
export ARM_TENANT_ID="fedcef2f-0c85-40dd-8f55-e23143dcb367"
export ARM_SUBSCRIPTION_ID="4910a5a6-aec6-405d-9294-c7f2845512a4"
export ARM_CLIENT_ID="7e14e768-6dac-44f4-886f-ba2990447f1f"
export ARM_CLIENT_SECRET="REPLACE_ME"

# Mirror to TF_VAR_* so terraform variables.tf picks up the secret too.
export TF_VAR_sp_client_secret="${ARM_CLIENT_SECRET}"

# Convenience for the AKS scripts.
export AKS_RESOURCE_GROUP="dev-stackable-rg"
export AKS_CLUSTER_NAME="uwv-platform-aks"
