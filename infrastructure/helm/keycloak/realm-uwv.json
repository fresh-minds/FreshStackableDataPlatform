      "clientId": "trino",
      "name": "Trino (UWV)",
      "enabled": true,
      "protocol": "openid-connect",
      "publicClient": false,
      "secret": "uwv-dev-only-CHANGE-ME-trino-secret",
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "serviceAccountsEnabled": true,
      "redirectUris": [
        "https://trino.uwv-platform.local:8443/*",
        "https://trino.uwv-platform.local/*"
      ],
      "webOrigins": [
        "+"
      ],
      "attributes": {
